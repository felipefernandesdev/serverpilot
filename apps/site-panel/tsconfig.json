{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "../../",
    "paths": {
      "@serverpilot/domain": ["packages/domain/src"],
      "@serverpilot/domain/*": ["packages/domain/src/*"],
      "@serverpilot/use-cases": ["packages/use-cases/src"],
      "@serverpilot/use-cases/*": ["packages/use-cases/src/*"],
      "@serverpilot/infra": ["packages/infra/src"],
      "@serverpilot/infra/*": ["packages/infra/src/*"],
      "@serverpilot/shared": ["packages/shared/src"],
      "@serverpilot/shared/*": ["packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
