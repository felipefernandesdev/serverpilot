# Database
DATABASE_URL="postgresql://user:password@localhost:5432/serverpilot?schema=public"

# For SQLite (development)
# DATABASE_URL="file:./dev.db"

# JWT
# HQ_JWT_SECRET — usado pelo admin API (ServerHQ)
# PANEL_JWT_SECRET — usado pelo client API (SitePanel)
# Separados por segurança (ADR-012). Gerados automaticamente no install.
HQ_JWT_SECRET="change-me-hq-secret"
PANEL_JWT_SECRET="change-me-panel-secret"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3000
NODE_ENV=development

# ServerPilot Admin
ADMIN_EMAIL="admin@serverpilot.local"
ADMIN_PASSWORD="change-this-password"

# Server Management
SSH_HOST="localhost"
SSH_PORT=22
SSH_USER="root"

# SSL/SSL
LETSENCRYPT_EMAIL="admin@serverpilot.local"

# Email (Exim/Dovecot)
SMTP_HOST="localhost"
SMTP_PORT=25

# DNS
DNS_NAMESERVERS="ns1.serverpilot.local,ns2.serverpilot.local"
