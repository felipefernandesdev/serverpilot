# Database
DATABASE_URL="postgresql://user:password@localhost:5432/serverpilot?schema=public"

# For SQLite (development)
# DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3000
NODE_ENV=development

# ServerPilot Admin
ADMIN_EMAIL="admin@serverpilot.local"
ADMIN_PASSWORD="change-this-password"

# Server Management
SSH_HOST="localhost"
SSH_PORT=22
SSH_USER="root"

# SSL/SSL
LETSENCRYPT_EMAIL="admin@serverpilot.local"

# Email (Exim/Dovecot)
SMTP_HOST="localhost"
SMTP_PORT=25

# DNS
DNS_NAMESERVERS="ns1.serverpilot.local,ns2.serverpilot.local"
